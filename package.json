{
  "name": "medimind-angio",
  "version": "0.1.0",
  "description": "Production-grade angiology reporting system — standalone web app, FHIR-native, ported from MediMind design patterns.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite --port 3001",
    "dev:lan": "vite --port 3001 --host",
    "build": "tsc -p tsconfig.build.json && vite build",
    "preview": "vite preview --port 3001",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'scripts/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' 'scripts/**/*.ts' --fix",
    "anatomy:fetch": "tsx scripts/fetch-anatomy.ts",
    "anatomy:tag": "tsx scripts/tag-anatomy.ts",
    "anatomy:verify": "tsx scripts/verify-anatomy.ts",
    "anatomy:all": "npm run anatomy:fetch && npm run anatomy:tag && npm run anatomy:verify",
    "i18n:check": "tsx scripts/check-i18n.ts",
    "validate:fhir": "tsx scripts/validate-sample-bundle.ts",
    "size-check": "tsx scripts/check-bundle-size.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@mantine/core": "8.3.6",
    "@mantine/dates": "8.3.6",
    "@mantine/form": "8.3.6",
    "@mantine/hooks": "8.3.6",
    "@mantine/notifications": "8.3.6",
    "@react-pdf/renderer": "^4.3.1",
    "@tabler/icons-react": "3.35.0",
    "dayjs": "^1.11.13",
    "idb-keyval": "^6.2.2",
    "perfect-freehand": "^1.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-router": "^7.14.2",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.17",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "@vitejs/plugin-react": "5.1.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@xmldom/xmldom": "^0.9.6",
    "css-select": "^5.1.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.5.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.10",
    "postcss-preset-mantine": "1.18.0",
    "tsx": "^4.19.2",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.2",
    "vitest": "^4.1.5",
    "xpath": "^0.0.34"
  }
}
